# Server Port
PORT=5000

# MongoDB URI (Local or MongoDB Atlas)
MONGODB_URI=mongodb://localhost:27017/netprime

# JWT Secret Keys
ACCESS_TOKEN_SECRET=your_short_lived_access_token_secret_32_chars
REFRESH_TOKEN_SECRET=your_long_lived_refresh_token_secret_64_chars

# Razorpay Configuration (Test/Live Credentials)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_key

# Firebase Admin configuration (Path to downloaded service-account JSON)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Nodemailer Configuration (For email verification and invoice delivery)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password

# Public Client URL (For email redirect links)
CLIENT_URL=http://localhost:5000

# Firebase Client SDK Configuration (For Real-time Google Sign-In popup)
FIREBASE_API_KEY=your_firebase_client_api_key
FIREBASE_AUTH_DOMAIN=your_firebase_client_auth_domain.firebaseapp.com
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_APP_ID=your_firebase_client_app_id

# Stripe Keys (For card subscription payments)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_key

